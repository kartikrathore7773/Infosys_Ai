# Copy this file to .env or .env.local in the frontend root and fill in the real values.

# OpenAI (primary LLM)
VITE_OPENAI_API_KEY=sk-your-openai-key

# Gemini (optional fallback)
VITE_GEMINI_API_KEY=your-gemini-key

# HuggingFace / Mistral (optional fallback)
VITE_HF_API_KEY=your-hf-key

# Backend API URL
VITE_BACKEND_URL=http://localhost:5000
